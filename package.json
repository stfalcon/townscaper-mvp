{
  "name": "cozy-town-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Townscaper-like sandbox game for kids 7-12, vanilla JS + Three.js",
  "scripts": {
    "dev": "serve . -p 3030 -L --no-clipboard",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^1.6.0",
    "serve": "^14.2.6",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
